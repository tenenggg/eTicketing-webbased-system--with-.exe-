{
  "name": "eticketing-client",
  "version": "1.0.0",
  "description": "Desktop client for eTicketing",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.eticketing.app",
    "productName": "eTicketing",
    "directories": {
      "output": "dist"
    },
    "extraFiles": [
      ".env",
      "error.html"
    ],
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}
