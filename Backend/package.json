{
  "name": "eticketing-backend",
  "version": "1.0.0",
  "description": "Real-time chat backend",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "pkg . --output eticketingServer.exe"
  },
  "pkg": {
    "scripts": [
      "**/*.js"
    ],
    "assets": [
      ".env",
      "frontend/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "."
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.3",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}